# Environment for building and running bevy-naadf.
#
# Copy this file to `.envrc` (gitignored) and set the values for your machine.
# With direnv it loads automatically; otherwise source it or export the
# variables however you prefer. After editing `.envrc`, run `direnv allow`.
#
# Both variables are read by the `dlss_wgpu` build script at build time, and
# DLSS_SDK is also read at runtime so NGX can locate the DLSS feature libraries.

# Root of an NVIDIA DLSS SDK checkout at tag v310.5.3 — https://github.com/NVIDIA/DLSS
export DLSS_SDK="/path/to/DLSS"

# Vulkan headers + loader prefix. The system prefix is fine on most Linux
# distros; point at the LunarG SDK's versioned directory if you use that.
export VULKAN_SDK="/usr"

# --- InstaMAT (optional; only needed to run the `instamat_bake` dev tool) ---
# Absolute path to libInstaMATNativeInterface.so, extracted from the
# "InstaMAT for Blender" plugin zip (instamat/DLLs/Linux64/). This wrapper is
# proprietary and is NOT vendored in this repo.
export INSTAMAT_NATIVE_INTERFACE="/path/to/libInstaMATNativeInterface.so"
# InstaMAT Studio install root (contains lib/libInstaMAT.so). Defaults to
# /opt/InstaMATStudio if unset.
export INSTAMAT_STUDIO="/opt/InstaMATStudio"
