# Cargo build artifacts (workspace-wide target dir)
/target

# Trunk WebGPU (wasm32) build output for the bevy_naadf crate
/crates/bevy_naadf/dist
/crates/bevy_naadf/.stage

# voxel_noise Emscripten (wasm32) build output
/crates/voxel_noise/dist

# Node / Playwright — the e2e harness and the cloudflare worker
node_modules/
/e2e/test-results
/e2e/playwright-report

# Local environment — machine-specific paths (see .envrc.example)
.envrc

# Detached-process log from `just`/IDE launches
nohup.out

# Bevy processed-asset pipeline output (`cargo run --features asset_processor`).
# `imported_assets/` is a regenerable cache; the AssetProcessor also writes
# default `.meta` sidecars next to sources that lack one — for shaders that is
# pure noise, and `sample.texarray.ron.meta` is regenerated from the registered
# default processor. The intentional, hand-written `*.png.meta` sidecars under
# src/assets/textures/ stay tracked.
/crates/bevy_naadf/imported_assets
/crates/bevy_naadf/src/assets/shaders/*.meta
/crates/bevy_naadf/src/assets/textures/sample.texarray.ron.meta
# Source-side processor metas the `bake` pass auto-writes next to every
# `*.texarray.ron` at assets/materials/. The hand-written `*.png.meta` sidecars
# next to the source maps stay tracked (they pin the `Load` opt-out).
/assets/materials/*.texarray.ron.meta
# `baked_material::MaterialRonLoader` is registered but has no default processor,
# so `material.ron` gets an auto-generated default `Load` meta on bake. Inert
# source-side noise — same treatment as the shaders.
/assets/materials/*/*.ron.meta
